# ============================================================
# BEES Breweries Pipeline — Environment Variables
# Copy this file to .env and fill in ALL values before running.
# NEVER commit .env to version control.
# CHANGE ALL PASSWORDS/KEYS BEFORE DEPLOYING TO PRODUCTION.
# ============================================================

# MinIO credentials (local S3-compatible storage)
MINIO_ACCESS_KEY=change-me-access-key
MINIO_SECRET_KEY=change-me-secret-key

# PostgreSQL password (Airflow metadata DB)
POSTGRES_PASSWORD=change-me-postgres-password

# Airflow Fernet key — used to encrypt connections/variables in the DB
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-fernet-key

# Airflow webserver secret key — separate from Fernet key (signs user sessions)
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
WEBSERVER_SECRET_KEY=change-me-webserver-secret

# Airflow admin user
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me-admin-password
AIRFLOW_ADMIN_EMAIL=admin@example.com

# Bucket names (override defaults if needed)
BRONZE_BUCKET=brewery-bronze
SILVER_BUCKET=brewery-silver
GOLD_BUCKET=brewery-gold
