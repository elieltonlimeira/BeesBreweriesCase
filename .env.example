# MinIO credentials (local S3-compatible storage)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Airflow Fernet key — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your-fernet-key-here

# Airflow admin credentials
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com

# API configuration (override defaults if needed)
# API_BASE_URL=https://api.openbrewerydb.org/v1/breweries
# API_PAGE_SIZE=200
# API_MAX_RETRIES=3

# Bucket names
BRONZE_BUCKET=brewery-bronze
SILVER_BUCKET=brewery-silver
GOLD_BUCKET=brewery-gold
